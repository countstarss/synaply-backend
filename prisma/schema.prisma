generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// MARK: - 用户模型
model User {
  id         String       @id @default(uuid())
  email      String       @unique
  name       String?
  avatarUrl  String?      @map("avatar_url")
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")
  teams      TeamMember[]
  workspaces Workspace[]

  @@map("users")
}

/// MARK: - 团队模型
model Team {
  id        String       @id @default(uuid())
  name      String
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")
  members   TeamMember[]
  workspace Workspace?

  @@map("teams")
}

/// MARK: - 团队成员模型
model TeamMember {
  id               String     @id @default(uuid())
  teamId           String     @map("team_id")
  userId           String     @map("user_id")
  role             Role       @default(MEMBER)
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")
  comments         Comment[]
  team             Team       @relation(fields: [teamId], references: [id])
  user             User       @relation(fields: [userId], references: [id])
  createdWorkflows Workflow[] @relation("CreatedWorkflows")
  // Project          Project[]

  @@unique([teamId, userId])
  @@map("team_members")
}

/// MARK: - 工作空间模型
model Workspace {
  id        String        @id @default(uuid())
  name      String
  type      WorkspaceType
  userId    String?       @map("user_id")
  teamId    String?       @unique @map("team_id")
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  issues    Issue[]
  projects  Project[]
  workflows Workflow[]
  team      Team?         @relation(fields: [teamId], references: [id])
  user      User?         @relation(fields: [userId], references: [id])

  @@map("workspaces")
}

/// MARK: - 项目模型 (可选层级)
model Project {
  id          String         @id @default(uuid())
  name        String
  description String?
  workspaceId String         @map("workspace_id")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  creatorId   String         @map("creator_id")
  visibility  VisibilityType @default(PRIVATE)
  // issues      Issue[]
  // creator     TeamMember     @relation("CreatedProjects", fields: [creatorId], references: [id])
  workspace   Workspace      @relation(fields: [workspaceId], references: [id])

  @@map("projects")
}

model Workflow {
  id                String         @id @default(uuid())
  name              String
  workspaceId       String         @map("workspace_id")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")
  status            WorkflowStatus @default(DRAFT)
  creatorId         String         @map("creator_id")
  visibility        VisibilityType @default(PRIVATE)
  assigneeMap       Json?
  json              Json?
  totalSteps        Int            @default(0)
  currentStepIndex  Int            @default(0)
  currentStepStatus IssueStatus    @default(TODO)
  version           String         @default("v1")
  isSystemTemplate  Boolean        @default(false) // 是否为系统级模板

  // issues    Issue[]
  creator   TeamMember @relation("CreatedWorkflows", fields: [creatorId], references: [id])
  workspace Workspace  @relation(fields: [workspaceId], references: [id])

  @@map("workflows")
}

model Issue {
  id               String    @id @default(uuid())
  title            String
  description      String?
  workspaceId      String    @map("workspace_id")
  // workflowId       String?   @map("workflow_id")
  directAssigneeId String?   @map("direct_assignee_id")
  creatorId        String    @map("creator_id")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  dueDate          DateTime? @map("due_date")
  workspace        Workspace @relation(fields: [workspaceId], references: [id])
  Comment          Comment[]

  @@map("issues")
}

model Comment {
  id        String     @id @default(uuid())
  content   String
  issueId   String     @map("issue_id")
  authorId  String     @map("author_id")
  parentId  String?
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  author    TeamMember @relation(fields: [authorId], references: [id])
  issue     Issue      @relation(fields: [issueId], references: [id])

  @@map("comments")
}

/// 用户角色枚举
enum Role {
  OWNER
  ADMIN
  MEMBER
}

/// 工作空间类型枚举
enum WorkspaceType {
  PERSONAL
  TEAM
}

/// 工作流状态枚举
enum WorkflowStatus {
  DRAFT
  PUBLISHED
}

/// Issue 状态枚举
enum IssueStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  DONE
}

/// Issue 优先级枚举
enum IssuePriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

/// 内容可见性类型枚举
/// 权限控制说明：
/// - PRIVATE: 仅创建者可见和编辑
/// - TEAM_READONLY: 团队成员可查看，但只有创建者可编辑
/// - TEAM_EDITABLE: 团队成员可查看和编辑
/// - PUBLIC: 完全公开（为未来扩展预留）
enum VisibilityType {
  PRIVATE
  TEAM_READONLY
  TEAM_EDITABLE
  PUBLIC
}
