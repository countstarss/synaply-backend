generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// MARK: - 用户模型
model User {
  id         String       @id @default(uuid())
  email      String       @unique
  name       String?
  avatarUrl  String?      @map("avatar_url")
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")
  teams      TeamMember[]
  workspaces Workspace[]

  @@map("users")
}

/// MARK: - 团队模型
model Team {
  id        String       @id @default(uuid())
  name      String
  avatarUrl String?      @map("avatar_url")
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")
  members   TeamMember[]
  workspace Workspace?

  @@map("teams")
}

/// MARK: - 团队成员模型
model TeamMember {
  id               String     @id @default(uuid())
  teamId           String     @map("team_id")
  userId           String     @map("user_id")
  role             Role       @default(MEMBER)
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")
  comments         Comment[]
  team             Team       @relation(fields: [teamId], references: [id])
  user             User       @relation(fields: [userId], references: [id])
  createdWorkflows Workflow[] @relation("CreatedWorkflows")

  Issue           Issue[]
  IssueStepRecord IssueStepRecord[]
  IssueActivity   IssueActivity[]
  Task            Task[]
  createdIssues   Issue[]           @relation("CreatedIssues")
  assignedIssues  IssueAssignee[]

  @@unique([teamId, userId])
  @@map("team_members")
}

/// MARK: - 工作空间模型
model Workspace {
  id          String        @id @default(uuid())
  name        String
  type        WorkspaceType
  userId      String?       @map("user_id")
  teamId      String?       @unique @map("team_id")
  issuePrefix String?       @map("issue_prefix") // Issue 编号前缀，如 "SYN"、"BE"
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  issues      Issue[]
  projects    Project[]
  workflows   Workflow[]
  team        Team?         @relation(fields: [teamId], references: [id])
  user        User?         @relation(fields: [userId], references: [id])
  calendar    Calendar?
  issueStates IssueState[]
  labels      Label[]

  @@map("workspaces")
}

/// MARK: - 项目模型 (可选层级)
model Project {
  id          String         @id @default(uuid())
  name        String
  description String?
  workspaceId String         @map("workspace_id")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  creatorId   String         @map("creator_id")
  visibility  VisibilityType @default(PRIVATE)
  issues      Issue[]
  workspace   Workspace      @relation(fields: [workspaceId], references: [id])

  @@map("projects")
}

model Workflow {
  id                String         @id @default(uuid())
  name              String
  workspaceId       String         @map("workspace_id")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")
  status            WorkflowStatus @default(DRAFT)
  creatorId         String         @map("creator_id")
  visibility        VisibilityType @default(PRIVATE)
  assigneeMap       Json?
  json              Json?
  totalSteps        Int            @default(0)
  currentStepIndex  Int            @default(0)
  currentStepStatus IssueStatus    @default(TODO)
  version           String         @default("v1")
  isSystemTemplate  Boolean        @default(false) // 是否为系统级模板

  // issues    Issue[]
  creator   TeamMember @relation("CreatedWorkflows", fields: [creatorId], references: [id])
  workspace Workspace  @relation(fields: [workspaceId], references: [id])

  @@map("workflows")
}

model Issue {
  id               String    @id @default(uuid())
  title            String
  description      String?
  workspaceId      String    @map("workspace_id")
  workflowId       String?   @map("workflow_id")
  directAssigneeId String?   @map("direct_assignee_id")
  creatorId        String    @map("creator_id")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  dueDate          DateTime? @map("due_date")

  // P0 新增字段
  stateId         String?        @map("state_id") // 关联 IssueState，主状态
  projectId       String?        @map("project_id") // 可选归属项目
  visibility      VisibilityType @default(TEAM_EDITABLE) // 可见性控制
  creatorMemberId String?        @map("creator_member_id") // 创建者 TeamMember ID
  key             String?        @unique // Issue 编号，如 "SYN-123"
  sequence        Int? // workspace 内自增序号

  // Workflow 相关字段 (保留，用于 WORKFLOW 类型)
  totalSteps        Int           @default(0)
  currentStepId     String?       @map("current_step_id") // 用于快速标识当前步骤（配合 snapshot 解析）
  currentStepIndex  Int           @default(0)
  currentStepStatus IssueStatus   @default(TODO)
  workflowSnapshot  Json?
  priority          IssuePriority @default(NORMAL)
  issueType         IssueType     @default(NORMAL)

  // Relations
  comments        Comment[]
  workspace       Workspace         @relation(fields: [workspaceId], references: [id])
  TeamMember      TeamMember?       @relation(fields: [teamMemberId], references: [id])
  teamMemberId    String?
  IssueStepRecord IssueStepRecord[]
  IssueActivity   IssueActivity[]
  state           IssueState?       @relation(fields: [stateId], references: [id])
  project         Project?          @relation(fields: [projectId], references: [id])
  creatorMember   TeamMember?       @relation("CreatedIssues", fields: [creatorMemberId], references: [id])
  assignees       IssueAssignee[]
  labels          IssueLabel[]

  @@index([workspaceId])
  @@index([stateId])
  @@index([projectId])
  @@index([creatorMemberId])
  @@map("issues")
}

/// MARK: - Issue 状态配置模型 (Linear 风格动态状态)
model IssueState {
  id          String             @id @default(uuid())
  workspaceId String             @map("workspace_id")
  name        String // 状态名称，如 "待处理"、"进行中"
  color       String             @default("#6B7280") // 状态颜色
  category    IssueStateCategory @default(TODO) // 状态分类，用于聚合统计
  position    Int                @default(0) // 排序位置
  isDefault   Boolean            @default(false) @map("is_default") // 是否为新建 Issue 默认状态
  isArchived  Boolean            @default(false) @map("is_archived") // 软删除标记
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  issues    Issue[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@map("issue_states")
}

/// MARK: - 标签模型
model Label {
  id          String   @id @default(uuid())
  workspaceId String   @map("workspace_id")
  name        String
  color       String   @default("#6B7280")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  workspace Workspace    @relation(fields: [workspaceId], references: [id])
  issues    IssueLabel[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@map("labels")
}

/// MARK: - Issue 标签关联表
model IssueLabel {
  id        String   @id @default(uuid())
  issueId   String   @map("issue_id")
  labelId   String   @map("label_id")
  createdAt DateTime @default(now()) @map("created_at")

  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  label Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@unique([issueId, labelId])
  @@map("issue_labels")
}

/// MARK: - Issue 分配人关联表
model IssueAssignee {
  id         String   @id @default(uuid())
  issueId    String   @map("issue_id")
  memberId   String   @map("member_id")
  assignedAt DateTime @default(now()) @map("assigned_at")

  issue  Issue      @relation(fields: [issueId], references: [id], onDelete: Cascade)
  member TeamMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([issueId, memberId])
  @@map("issue_assignees")
}

// NOTE: 用来记录issue step的信息
model IssueStepRecord {
  id          String     @id @default(uuid())
  issueId     String     @map("issue_id")
  stepId      String // 来自 snapshot JSON 中的某个节点 ID
  stepName    String
  index       Int
  resultText  String?
  attachments Json? // 存图片、文件、link 等
  assigneeId  String     @map("assignee_id")
  createdAt   DateTime   @default(now()) @map("created_at")
  issue       Issue      @relation(fields: [issueId], references: [id])
  assignee    TeamMember @relation(fields: [assigneeId], references: [id])
}

// NOTE: 用来记录issue的操作历史，比如：
// 1. 创建issue
// 2. 更新issue
// 3. 删除issue
// 4. 更新issue的step
// 5. 更新issue的assignee
model IssueActivity {
  id        String   @id @default(uuid())
  issueId   String   @map("issue_id")
  actorId   String   @map("actor_id") // 操作人（TeamMember）
  action    String   @map("action") // 操作描述（可预设或自由填写）
  metadata  Json?    @map("metadata") // 附带数据（如字段变更前后值）
  createdAt DateTime @default(now()) @map("created_at")

  issue Issue      @relation(fields: [issueId], references: [id])
  actor TeamMember @relation(fields: [actorId], references: [id])

  @@index([issueId])
  @@index([actorId])
  @@map("issue_activities")
}

model Comment {
  id          String     @id @default(uuid())
  content     String
  issueId     String     @map("issue_id")
  workspaceId String     @map("workspace_id")
  authorId    String     @map("author_id")
  parentId    String?    @map("parent_id")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  author      TeamMember @relation(fields: [authorId], references: [id])
  issue       Issue      @relation(fields: [issueId], references: [id])

  @@map("comments")
}

/// MARK: - 日历模型
model Calendar {
  id          String   @id @default(uuid())
  name        String
  workspaceId String   @unique @map("workspace_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tasks     Task[]
  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@map("calendars")
}

/// MARK: - 任务模型
model Task {
  id          String     @id @default(uuid())
  title       String
  description String?
  calendarId  String     @map("calendar_id")
  dueDate     DateTime?
  status      TaskStatus @default(PENDING)
  createdById String?    @map("created_by_id")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  calendar  Calendar    @relation(fields: [calendarId], references: [id])
  createdBy TeamMember? @relation(fields: [createdById], references: [id])

  @@map("tasks")
}

/// Task 状态枚举
enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

/// 用户角色枚举
enum Role {
  OWNER
  ADMIN
  MEMBER
}

/// 工作空间类型枚举
enum WorkspaceType {
  PERSONAL
  TEAM
}

/// 工作流状态枚举
enum WorkflowStatus {
  DRAFT
  PUBLISHED
}

/// Issue 状态枚举 (保留用于 Workflow Step 状态)
enum IssueStatus {
  TODO
  IN_PROGRESS
  AMOST_DONE
  BLOCKED
  DONE
}

/// Issue 状态分类枚举 (用于 IssueState 的分类聚合)
enum IssueStateCategory {
  BACKLOG
  TODO
  IN_PROGRESS
  DONE
  CANCELED
}

/// Issue 优先级枚举
enum IssuePriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

/// Issue 类型枚举
enum IssueType {
  NORMAL
  WORKFLOW
}

/// 内容可见性类型枚举
/// 权限控制说明：
/// - PRIVATE: 仅创建者可见和编辑
/// - TEAM_READONLY: 团队成员可查看，但只有创建者可编辑
/// - TEAM_EDITABLE: 团队成员可查看和编辑
/// - PUBLIC: 完全公开（为未来扩展预留）
enum VisibilityType {
  PRIVATE
  TEAM_READONLY
  TEAM_EDITABLE
  PUBLIC
}
