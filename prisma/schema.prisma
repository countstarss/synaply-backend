generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// MARK: - 用户模型
model User {
  id         String       @id @default(uuid())
  email      String       @unique
  name       String?
  avatarUrl  String?      @map("avatar_url")
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")
  teams      TeamMember[]
  workspaces Workspace[]

  @@map("users")
}

/// MARK: - 团队模型
model Team {
  id        String       @id @default(uuid())
  name      String
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")
  members   TeamMember[]
  workspace Workspace?

  @@map("teams")
}

/// MARK: - 团队成员模型
model TeamMember {
  id                     String             @id @default(uuid())
  teamId                 String             @map("team_id")
  userId                 String             @map("user_id")
  role                   Role               @default(MEMBER)
  createdAt              DateTime           @default(now()) @map("created_at")
  updatedAt              DateTime           @updatedAt @map("updated_at")
  comments               Comment[]
  issueActivities        IssueActivity[]
  progressLogs           IssueProgressLog[] @relation("ProgressLogActor")
  assignedProgress       IssueProgressLog[]
  createdIssues          Issue[]            @relation("CreatedIssues")
  directlyAssignedIssues Issue[]            @relation("DirectAssignedIssues")
  createdProjects        Project[]          @relation("CreatedProjects")
  team                   Team               @relation(fields: [teamId], references: [id])
  user                   User               @relation(fields: [userId], references: [id])
  createdWorkflows       Workflow[]         @relation("CreatedWorkflows")

  @@unique([teamId, userId])
  @@map("team_members")
}

/// MARK: - 工作空间模型
model Workspace {
  id        String        @id @default(uuid())
  name      String
  type      WorkspaceType
  userId    String?       @map("user_id")
  teamId    String?       @unique @map("team_id")
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  issues    Issue[]
  projects  Project[]
  workflows Workflow[]
  team      Team?         @relation(fields: [teamId], references: [id])
  user      User?         @relation(fields: [userId], references: [id])

  @@map("workspaces")
}

/// MARK: - 项目模型 (可选层级)
model Project {
  id          String         @id @default(uuid())
  name        String
  description String?
  workspaceId String         @map("workspace_id")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  creatorId   String         @map("creator_id")
  visibility  VisibilityType @default(PRIVATE)
  issues      Issue[]
  creator     TeamMember     @relation("CreatedProjects", fields: [creatorId], references: [id])
  workspace   Workspace      @relation(fields: [workspaceId], references: [id])

  @@map("projects")
}

model Workflow {
  id          String         @id @default(uuid())
  name        String
  workspaceId String         @map("workspace_id")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  status      WorkflowStatus @default(DRAFT)
  creatorId   String         @map("creator_id")
  visibility  VisibilityType @default(PRIVATE)
  assigneeMap Json?
  json        Json?
  totalSteps  Int            @default(0)
  version     String         @default("v1")
  issues      Issue[]
  creator     TeamMember     @relation("CreatedWorkflows", fields: [creatorId], references: [id])
  workspace   Workspace      @relation(fields: [workspaceId], references: [id])

  @@map("workflows")
}

model Issue {
  id               String             @id @default(uuid())
  title            String
  description      String?
  workspaceId      String             @map("workspace_id")
  workflowId       String?            @map("workflow_id")
  directAssigneeId String?            @map("direct_assignee_id")
  creatorId        String             @map("creator_id")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")
  dueDate          DateTime?          @map("due_date")
  parentTaskId     String?            @map("parent_task_id")
  priority         IssuePriority      @default(NORMAL)
  startDate        DateTime?          @map("start_date")
  status           IssueStatus        @default(TODO)
  projectId        String?            @map("project_id")
  visibility       VisibilityType     @default(PRIVATE)
  currentStepId    String?            @map("current_step_id")
  progressLog      Json?
  workflowSnapshot Json?
  comments         Comment[]
  activities       IssueActivity[]
  blockingIssues   IssueDependency[]  @relation("BlockingIssue")
  dependsOnIssues  IssueDependency[]  @relation("DependsOnIssue")
  progressLogs     IssueProgressLog[]
  creator          TeamMember         @relation("CreatedIssues", fields: [creatorId], references: [id])
  directAssignee   TeamMember?        @relation("DirectAssignedIssues", fields: [directAssigneeId], references: [id])
  parentTask       Issue?             @relation("Subtask", fields: [parentTaskId], references: [id])
  subtasks         Issue[]            @relation("Subtask")
  project          Project?           @relation(fields: [projectId], references: [id])
  workflow         Workflow?          @relation(fields: [workflowId], references: [id])
  workspace        Workspace          @relation(fields: [workspaceId], references: [id])

  @@map("issues")
}

model IssueActivity {
  id           String     @id @default(uuid())
  issueId      String     @map("issue_id")
  actorId      String     @map("actor_id")
  fromStepName String?
  toStepName   String
  comment      String?
  createdAt    DateTime   @default(now()) @map("created_at")
  actor        TeamMember @relation(fields: [actorId], references: [id])
  issue        Issue      @relation(fields: [issueId], references: [id])

  @@map("issue_activities")
}

model Comment {
  id        String     @id @default(uuid())
  content   String
  issueId   String     @map("issue_id")
  authorId  String     @map("author_id")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  author    TeamMember @relation(fields: [authorId], references: [id])
  issue     Issue      @relation(fields: [issueId], references: [id])

  @@map("comments")
}

model IssueDependency {
  id               String   @id @default(uuid())
  blockerIssueId   String   @map("blocker_issue_id")
  dependsOnIssueId String   @map("depends_on_issue_id")
  createdAt        DateTime @default(now()) @map("created_at")
  blockerIssue     Issue    @relation("BlockingIssue", fields: [blockerIssueId], references: [id])
  dependsOnIssue   Issue    @relation("DependsOnIssue", fields: [dependsOnIssueId], references: [id])

  @@unique([blockerIssueId, dependsOnIssueId])
  @@map("issue_dependencies")
}

model IssueProgressLog {
  id          String      @id @default(uuid())
  issueId     String      @map("issue_id")
  stepId      String
  stepName    String
  fromStatus  String?
  toStatus    String
  assigneeId  String?     @map("assignee_id")
  actorId     String      @map("actor_id")
  comment     String?
  attachments Json?
  createdAt   DateTime    @default(now()) @map("created_at")
  actor       TeamMember  @relation("ProgressLogActor", fields: [actorId], references: [id])
  assignee    TeamMember? @relation(fields: [assigneeId], references: [id])
  issue       Issue       @relation(fields: [issueId], references: [id])

  @@map("issue_progress_logs")
}

/// 用户角色枚举
enum Role {
  OWNER
  ADMIN
  MEMBER
}

/// 工作空间类型枚举
enum WorkspaceType {
  PERSONAL
  TEAM
}

/// 工作流状态枚举
enum WorkflowStatus {
  DRAFT
  PUBLISHED
}

/// Issue 状态枚举
enum IssueStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  DONE
}

/// Issue 优先级枚举
enum IssuePriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

/// 聊天类型枚举
enum ChatType {
  PRIVATE
  GROUP
}

/// 消息类型枚举
enum MessageType {
  TEXT
  IMAGE
  FILE
  SYSTEM
}

/// 内容可见性类型枚举
/// 权限控制说明：
/// - PRIVATE: 仅创建者可见和编辑
/// - TEAM_READONLY: 团队成员可查看，但只有创建者可编辑
/// - TEAM_EDITABLE: 团队成员可查看和编辑
/// - PUBLIC: 完全公开（为未来扩展预留）
enum VisibilityType {
  PRIVATE
  TEAM_READONLY
  TEAM_EDITABLE
  PUBLIC
}
